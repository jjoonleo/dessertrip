# Local Docker MongoDB settings
MONGO_DB=dessertrip
MONGO_PORT=27019
MONGO_ROOT_USERNAME=local-root-user
MONGO_ROOT_PASSWORD=replace-with-a-local-docker-password

# Runtime settings
MONGODB_URI=mongodb://local-root-user:replace-with-a-local-docker-password@127.0.0.1:27019/dessertrip?authSource=admin
AUTH_SECRET=replace-with-a-long-random-secret

# One-time admin seed settings
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
